<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/statsRoot"
    android:background="@color/light_bg"
    android:tag="root">

    <LinearLayout
        android:id="@+id/statsTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Habit Tracker"
            android:tag="text_title"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/light_text_primary"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TWÓJ NAJDŁUŻSZY NAWYK"
            android:tag="label"
            android:textSize="12sp"
            android:textColor="@color/light_text_secondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/topHabitCard"
            android:tag="card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTopHabitName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Brak nawyków"
                android:tag="text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/light_text_primary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvTopHabitStreak"
                android:tag="text_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/light_text_secondary"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TWOJE WSZYSTKIE NAWYKI"
            android:tag="label"
            android:textSize="12sp"
            android:textColor="@color/light_text_secondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/statsTop"
        android:layout_above="@id/bottomNavStats"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/allHabitsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

    <include
        android:id="@+id/bottomNavStats"
        layout="@layout/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:tag="bottom_nav"/>

</RelativeLayout>