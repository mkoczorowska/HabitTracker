<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/detailsRoot"
    android:background="?android:attr/colorBackground"
    android:tag="root">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gradient header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_gradient"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/tvHabitTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvHabitDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#C5CAE9"/>

        </LinearLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="20dp">

            <!-- Streak card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:gravity="center"
                android:layout_marginBottom="14dp"
                android:tag="card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TWOJA SERIA"
                    android:textSize="10sp"
                    android:textColor="@color/light_text_secondary"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp"
                    android:tag="text_secondary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="40sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvStreakDays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="52sp"
                    android:textStyle="bold"
                    android:textColor="@color/light_text_primary"
                    android:lineSpacingMultiplier="0.9"
                    android:tag="text_primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="dni z rzędu"
                    android:textSize="13sp"
                    android:textColor="@color/light_text_secondary"
                    android:layout_marginBottom="4dp"
                    android:tag="text_secondary"/>

                <TextView
                    android:id="@+id/tvStreakStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/light_text_secondary"
                    android:tag="text_secondary"/>

            </LinearLayout>

            <!-- Buttons -->
            <Button
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🗑  Usuń nawyk"
                android:tag="btn_delete"
                android:textColor="#E53935"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_delete"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Wróć"
                android:tag="btn_outline"
                android:textColor="@color/light_text_primary"
                android:textSize="15sp"
                android:background="@drawable/bg_button_outline"
                android:stateListAnimator="@null"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>