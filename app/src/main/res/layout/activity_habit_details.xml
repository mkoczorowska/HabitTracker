<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:id="@+id/detailsRoot"
    android:background="@color/light_bg">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Habit Tracker"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/light_text_primary"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="24dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tvHabitTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/light_text_primary"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/light_border"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvHabitDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/light_text_secondary"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="24dp"
        android:layout_marginBottom="32dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥"
            android:textSize="36sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvStreakDays"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/light_text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="dni z rzędu"
            android:textSize="14sp"
            android:textColor="@color/light_text_secondary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvStreakStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/light_text_secondary"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnDelete"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Usuń nawyk"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:background="@drawable/bg_button"
        android:stateListAnimator="@null"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Wróć"
        android:textColor="@color/light_text_primary"
        android:textSize="16sp"
        android:background="@drawable/bg_button_outline"
        android:stateListAnimator="@null"/>

</LinearLayout>