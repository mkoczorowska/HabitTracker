<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/settingsRoot"
    android:background="@color/light_bg"
    android:tag="root">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavSettings">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Habit Tracker"
                android:tag="text_title"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/light_text_primary"
                android:gravity="center"
                android:layout_marginBottom="32dp"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="USTAWIENIA"
                android:tag="label"
                android:textSize="11sp"
                android:textColor="@color/light_text_secondary"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <!-- Account card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:tag="card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Konto"
                    android:tag="label"
                    android:textSize="11sp"
                    android:textColor="@color/light_text_secondary"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvEmail"
                    android:tag="text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/light_text_primary"
                    android:textStyle="bold"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Wyloguj"
                android:tag="btn_primary"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_button"
                android:stateListAnimator="@null"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PERSONALIZACJA"
                android:tag="label"
                android:textSize="11sp"
                android:textColor="@color/light_text_secondary"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <!-- Dark mode card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:tag="card"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Motyw ciemny"
                    android:tag="text_primary"
                    android:textSize="15sp"
                    android:textColor="@color/light_text_primary"/>

                <Switch
                    android:id="@+id/switchDarkMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/check_color"
                    android:trackTint="#CCCCCC"/>

            </LinearLayout>

            <!-- Notifications card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="32dp"
                android:gravity="center_vertical"
                android:tag="card">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Włącz powiadomienia"
                        android:tag="text_primary"
                        android:textSize="15sp"
                        android:textColor="@color/light_text_primary"
                        android:layout_marginBottom="2dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Codzienny reminder o 8:00"
                        android:tag="text_secondary"
                        android:textSize="11sp"
                        android:textColor="@color/light_text_secondary"/>

                </LinearLayout>

                <Switch
                    android:id="@+id/switchNotifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/check_color"
                    android:trackTint="#CCCCCC"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/bottomNavSettings"
        layout="@layout/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:tag="bottom_nav"/>

</RelativeLayout>