<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/settingsRoot"
    android:background="?android:attr/colorBackground"
    android:tag="root">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavSettings">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Gradient header with avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_header_gradient"
                android:paddingTop="24dp"
                android:paddingBottom="28dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <!-- Avatar circle -->
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvAvatarLetter"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="?"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="4dp"
                    android:tag="text_primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ustawienia"
                    android:textSize="11sp"
                    android:textColor="#C5CAE9"/>

            </LinearLayout>

            <!-- Settings body -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingTop="24dp">

                <!-- Section: Konto -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="KONTO"
                    android:tag="label"
                    android:textSize="10sp"
                    android:textColor="@color/light_text_secondary"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp"/>

                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Wyloguj się"
                    android:tag="btn_primary"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="24dp"/>

                <!-- Section: Personalizacja -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PERSONALIZACJA"
                    android:tag="label"
                    android:textSize="10sp"
                    android:textColor="@color/light_text_secondary"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp"/>

                <!-- Dark mode toggle card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:padding="18dp"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:tag="card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙"
                        android:textSize="20sp"
                        android:layout_marginEnd="14dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tryb ciemny"
                        android:tag="text_primary"
                        android:textSize="14sp"
                        android:textColor="@color/light_text_primary"/>

                    <Switch
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/check_color"
                        android:trackTint="#CCCCCC"/>

                </LinearLayout>

                <!-- Notifications toggle card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:padding="18dp"
                    android:layout_marginBottom="32dp"
                    android:gravity="center_vertical"
                    android:tag="card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔"
                        android:textSize="20sp"
                        android:layout_marginEnd="14dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Powiadomienia"
                            android:tag="text_primary"
                            android:textSize="14sp"
                            android:textColor="@color/light_text_primary"
                            android:layout_marginBottom="2dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Codzienny reminder o 8:00"
                            android:tag="text_secondary"
                            android:textSize="11sp"
                            android:textColor="@color/light_text_secondary"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/check_color"
                        android:trackTint="#CCCCCC"/>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/bottomNavSettings"
        layout="@layout/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:tag="bottom_nav"/>

</RelativeLayout>