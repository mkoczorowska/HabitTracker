<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/addHabitRoot"
    android:background="@color/light_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Habit Tracker"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/light_text_primary"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nowy nawyk"
            android:textSize="16sp"
            android:textColor="@color/light_text_secondary"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tytuł nawyku"
            android:textSize="13sp"
            android:textColor="@color/light_text_secondary"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etHabitTitle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:hint="np. Codzienny spacer"
            android:textColorHint="#AAAAAA"
            android:textColor="@color/light_text_primary"
            android:inputType="textCapSentences"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opis (opcjonalnie)"
            android:textSize="13sp"
            android:textColor="@color/light_text_secondary"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etHabitDesc"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:hint="Opisz swój nawyk..."
            android:textColorHint="#AAAAAA"
            android:textColor="@color/light_text_primary"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dni tygodnia"
            android:textSize="13sp"
            android:textColor="@color/light_text_secondary"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <TextView android:id="@+id/tvMon"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="Pn"
                android:gravity="center" android:textSize="12sp"
                android:background="@drawable/bg_day_unselected"
                android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true"/>

            <TextView android:id="@+id/tvTue"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="Wt"
                android:gravity="center" android:textSize="12sp"
                android:background="@drawable/bg_day_unselected"
                android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true"/>

            <TextView android:id="@+id/tvWed"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="Śr"
                android:gravity="center" android:textSize="12sp"
                android:background="@drawable/bg_day_unselected"
                android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true"/>

            <TextView android:id="@+id/tvThu"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="Cz"
                android:gravity="center" android:textSize="12sp"
                android:background="@drawable/bg_day_unselected"
                android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true"/>

            <TextView android:id="@+id/tvFri"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="Pt"
                android:gravity="center" android:textSize="12sp"
                android:background="@drawable/bg_day_unselected"
                android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true"/>

            <TextView android:id="@+id/tvSat"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="Sb"
                android:gravity="center" android:textSize="12sp"
                android:background="@drawable/bg_day_unselected"
                android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true"/>

            <TextView android:id="@+id/tvSun"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="Nd"
                android:gravity="center" android:textSize="12sp"
                android:background="@drawable/bg_day_unselected"
                android:clickable="true" android:focusable="true"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Zapisz nawyk"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/bg_button"
            android:stateListAnimator="@null"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Anuluj"
            android:textColor="@color/light_text_primary"
            android:textSize="16sp"
            android:background="@drawable/bg_button_outline"
            android:stateListAnimator="@null"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>