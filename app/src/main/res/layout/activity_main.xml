<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:id="@+id/mainRoot"
    android:tag="root">
    <!-- Tło ustawia ThemeHelper dynamicznie — nie hardkodujemy koloru -->

    <!-- Gradient hero header -->
    <LinearLayout
        android:id="@+id/heroSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_header_gradient"
        android:paddingBottom="48dp"
        android:tag="header">

        <TextView
            android:id="@+id/tvAppIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="✦"
            android:textSize="40sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/bg_icon_circle"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Habit Tracker"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.02"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buduj dobre nawyki każdego dnia"
            android:textSize="15sp"
            android:textColor="#C5CAE9"
            android:gravity="center"/>

    </LinearLayout>

    <!-- Buttons section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:paddingTop="40dp">

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Zaloguj się"
            android:tag="btn_primary"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button"
            android:layout_marginBottom="14dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Zarejestruj się"
            android:tag="btn_outline"
            android:textSize="16sp"
            android:background="@drawable/bg_button_outline"
            android:stateListAnimator="@null"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Twoje postępy czekają 🚀"
            android:textSize="12sp"
            android:tag="text_secondary"
            android:gravity="center"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</LinearLayout>